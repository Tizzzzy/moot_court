# OpenAI API Key for document extraction and evidence analysis
OPENAI_API_KEY=your_openai_api_key_here

# Google Gemini API Key for court simulator
GEMINI_API_KEY=your_gemini_api_key_here

# HuggingFace Token for model access (if needed)
HUGGINGFACE_TOKEN=your_hf_token_here

# Database configuration
DATABASE_URL=sqlite:///./moot_court.db

# GPU Configuration for MinerU
MINERU_DEVICE_MODE=cuda
CUDA_VISIBLE_DEVICES=0

# Optional: Override default data directory location
# If not set, defaults to {project_root}/data
# Must be an absolute path with drive letter on Windows
# Examples:
#   Windows: BASE_DATA_DIR=C:/Users/YourName/moot_court_data
#   Mac/Linux: BASE_DATA_DIR=/home/username/moot_court_data
#   Server: BASE_DATA_DIR=/mnt/data/moot_court
# BASE_DATA_DIR=

# Maximum file upload size in MB
MAX_UPLOAD_SIZE_MB=50
